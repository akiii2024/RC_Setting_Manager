# Firebase Functions secrets are managed with the Firebase CLI, not passed to Flutter.
# Set them with:
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set OPENWEATHER_API_KEY

# Optional Flutter compile-time override. Defaults to asia-northeast1.
FIREBASE_FUNCTIONS_REGION=asia-northeast1

# Firebase client SDK options are generated by FlutterFire CLI.
# Firebase Web/Android/iOS API keys are not treated as server secrets, but should
# still be restricted in Google Cloud / Firebase console where possible.
